---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';

// Fetch projects
const allProjects = await getCollection('projects');

// Sort by sortDate metadata (Newest first), fallback to 0
const sortedProjects = [...allProjects].sort((a, b) => {
  const dateA = a.data.sortDate ? new Date(a.data.sortDate).getTime() : 0;
  const dateB = b.data.sortDate ? new Date(b.data.sortDate).getTime() : 0;
  return dateB - dateA;
});

const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');
const resolvePath = (p: string | undefined) => p ? (p.startsWith('/') ? basePath + p : p) : p;

const categoriesInfo = [
  {
    id: 'Fun',
    title: 'FUN',
    descTitle: 'Games and experiment projects',
    descText: 'LEARNING THRU PLAY AND INTERACTION'
  },
  {
    id: 'Projects',
    title: 'PROJECTS',
    descTitle: 'Selected works',
    descText: 'BUILDING PRODUCTS FROM ZERO TO ONE'
  },
  {
    id: 'Brands',
    title: 'BRANDS',
    descTitle: 'Brand identities',
    descText: 'CRAFTING VISUAL STORIES'
  }
];
---

<Layout title="Joy Object">
  <div class="site-wrapper">
    <Sidebar />
    <main class="main-content">
      
      <!-- Header Section -->
      <section class="grid-container header-section">
        <div class="header-title">
          <h1 class="text-hero">
            Designing with code,<br> Building with purpose.
          </h1>
        </div>
        <div class="header-meta">
          <p class="text-h3" style="text-transform: uppercase; text-align: left;">
            DESIGN ENGINEER AT THE INTERSECTION OF PRODUCT CRAFT AND PRODUCTION CODE. EX-KAHOOT! FOUNDER & BUILDER.
          </p>
        </div>
      </section>

      {categoriesInfo.map(category => {
        const categoryProjects = sortedProjects.filter(p => (p.data.category || 'Fun') === category.id);
        
        if (categoryProjects.length === 0) return null;

        return (
          <div class="category-group" id={`category-${category.id.toLowerCase()}`}>
            
            <div class="grid-container" style="position: sticky; top: 40px; z-index: 10; height: 0; pointer-events: none;">
              <div class="category-title" style="pointer-events: auto;">
                <h2 class="text-h3">{category.title}</h2>
              </div>
            </div>

            <section class="grid-container category-header">
              <div class="category-desc">
                <p class="text-body-bold category-desc-title">{category.descTitle}</p>
                <h3 class="text-h3" style="max-width: 404px;">{category.descText}</h3>
              </div>
            </section>

            {categoryProjects.map((project) => (
              <section class="grid-container project-item">
                {project.data.floatingCardImage && (
                  <div class="floating-card" style="position: absolute; left: 20px; top: 120px; width: 308px; z-index: 1; opacity: 0.8; pointer-events: none;">
                    <img src={resolvePath(project.data.floatingCardImage)} alt="" style="width: 100%;" />
                  </div>
                )}

                <div class="project-name-container">
                  <h2 class="text-h2">{project.data.title}</h2>
                  {project.data.date && (
                    <span class="text-body-mono project-year">{project.data.date}</span>
                  )}
                </div>

                <div class="project-meta">
                  <p class="text-body" style="margin-bottom: 24px;">
                    {project.data.description}
                  </p>
                  {project.data.role && (
                    <p class="text-body-mono" style="color: var(--text-muted)">
                      {project.data.role}
                    </p>
                  )}
                </div>

                <div class={`project-image-container ${project.data.alignRight ? 'align-right' : 'rounded'}`} style={project.data.marginTop ? `margin-top: ${project.data.marginTop}px;` : undefined}>
                  {project.data.maskImage ? (
                    <div class="mockup-mask" style={`-webkit-mask-image: url('${resolvePath(project.data.maskImage)}'); mask-image: url('${resolvePath(project.data.maskImage)}');`}>
                      {project.data.coverImage?.endsWith('.mp4') ? (
                        <video src={resolvePath(project.data.coverImage)} autoplay loop muted playsinline style="width: 100%; height: auto; display: block;" />
                      ) : (
                        <img src={resolvePath(project.data.coverImage)} alt={`${project.data.title} mockup`} />
                      )}
                    </div>
                  ) : (
                    project.data.coverImage?.endsWith('.mp4') ? (
                      <video src={resolvePath(project.data.coverImage)} autoplay loop muted playsinline style="width: 100%; height: auto; display: block;" />
                    ) : (
                      <img src={resolvePath(project.data.coverImage)} alt={`${project.data.title} mockup`} />
                    )
                  )}
                </div>
              </section>
            ))}

          </div>
        );
      })}

    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Hide everything that isn't the intro elements right away so they don't flash
  gsap.set(".category-group, .sidebar-menu, .sidebar-bottom", { opacity: 0, y: 30 });

  // 1. Entrance Animations
  const tl = gsap.timeline();
  
  const introElements = [".sidebar-top", ".header-title h1", ".header-meta p"];

  tl.fromTo(introElements, 
      { y: "35vh", opacity: 0 },
      { y: "35vh", opacity: 1, duration: 1, stagger: 0.1, ease: "power3.out" }
    )
    .to(introElements, { 
      y: 0, 
      duration: 1.2, 
      ease: "power3.inOut", 
      delay: 0.5 
    })
    .to(".category-group, .sidebar-menu, .sidebar-bottom", { 
      y: 0, 
      opacity: 1, 
      duration: 1, 
      stagger: 0.1,
      ease: "power3.out" 
    }, "-=0.4"); // start gliding up just as the intro finishes moving

  // 2. ScrollTriggers for Projects
  const projects = document.querySelectorAll('.project-item');
  
  projects.forEach((project) => {
    // Select the elements we want to stagger in
    const elements = project.querySelectorAll('.project-meta, .project-name-container, .project-image-container, .floating-card');

    gsap.from(elements, {
      y: 80,
      opacity: 0,
      duration: 1.2,
      stagger: 0.15,
      ease: "power3.out",
      scrollTrigger: {
        trigger: project,
        start: "top 85%",
      }
    });

    // Parallax Effect for the mockup images
    const imgContainer = project.querySelector('.project-image-container');
    const img = imgContainer?.querySelector('img, video');
    
    if (img) {
      // Scale up slightly so the edges don't show when parallaxing inside the mask
      gsap.set(img, { scale: 1.15, transformOrigin: "center center" });
      
      gsap.to(img, {
        yPercent: 15,
        ease: "none",
        scrollTrigger: {
          trigger: imgContainer,
          start: "top bottom",
          end: "bottom top",
          scrub: 1 // smooth scrubbing
        }
      });
    }

    // Parallax for floating background card (if it exists)
    const floatingCard = project.querySelector('.floating-card');
    if (floatingCard) {
      gsap.to(floatingCard, {
        y: -50, // Move up as user scrolls down
        ease: "none",
        scrollTrigger: {
          trigger: project,
          start: "top bottom",
          end: "bottom top",
          scrub: true
        }
      });
    }
  });
</script>